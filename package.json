{
  "name": "zeta-vscode",
  "displayName": "Zeta Edit Prediction",
  "description": "Zeta 2.1 edit prediction + FIM autocomplete for VS Code via llama.cpp",
  "version": "0.1.0",
  "publisher": "local",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/volcano-kitchen/zeta-vscode.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Programming Languages", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zeta-sidebar",
          "title": "Zeta",
          "icon": "media/zeta-icon.svg"
        }
      ]
    },
    "views": {
      "zeta-sidebar": [
        {
          "type": "webview",
          "id": "zeta.sidebar",
          "name": "Zeta Control Panel"
        }
      ]
    },
    "commands": [
      {
        "command": "zeta.showMenu",
        "title": "Zeta: Show Menu"
      },
      {
        "command": "zeta.toggleEnabled",
        "title": "Zeta: Toggle Enable/Disable"
      },
      {
        "command": "zeta.acceptAndAdvance",
        "title": "Zeta: Accept current edit and advance to next region"
      },
      {
        "command": "zeta.jumpToNextEditLocation",
        "title": "Zeta: Jump to next edit prediction location"
      },
      {
        "command": "zeta.jumpToPrevEditLocation",
        "title": "Zeta: Jump to previous edit prediction location"
      },
      {
        "command": "zeta.acceptAllEdits",
        "title": "Zeta: Accept all pending edit predictions"
      },
      {
        "command": "zeta.dismissPrediction",
        "title": "Zeta: Dismiss current edit prediction"
      },
      {
        "command": "zeta.testServer",
        "title": "Zeta: Test Server Connection"
      },
      {
        "command": "zeta.forcePredict",
        "title": "Zeta: Force Trigger Prediction"
      }
    ],
    "configuration": {
      "title": "Zeta",
      "properties": {
        "zeta.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "llama.cpp server URL for Zeta 2.1 (OpenAI-compatible /v1/completions endpoint)"
        },
        "zeta.modelName": {
          "type": "string",
          "default": "zeta-2.1",
          "description": "Model name sent in /v1/completions requests"
        },
        "zeta.maxContextTokens": {
          "type": "number",
          "default": 28672,
          "description": "Max prompt tokens before truncation (model has 32K context, leaving room for output)"
        },
        "zeta.debounceMs": {
          "type": "number",
          "default": 250,
          "description": "Debounce delay in ms before triggering a completion request"
        },
        "zeta.temperature": {
          "type": "number",
          "default": 0.1,
          "description": "Sampling temperature for completions"
        },
        "zeta.maxFimTokens": {
          "type": "number",
          "default": 64,
          "description": "Max tokens for FIM autocomplete responses"
        },
        "zeta.maxEditPredictionTokens": {
          "type": "number",
          "default": 256,
          "description": "Max tokens for edit prediction responses"
        },
        "zeta.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Zeta completions globally"
        },
        "zeta.enableEditPrediction": {
          "type": "boolean",
          "default": false,
          "description": "Enable next-edit prediction (Phase 2 - requires edit history tracking)"
        },
        "zeta.experimentalInjectLsp": {
          "type": "boolean",
          "default": false,
          "description": "[Experimental] Inject LSP diagnostic and symbol info into prompt context"
        },
        "zeta.fimContextLines": {
          "type": "number",
          "default": 100,
          "description": "Number of context lines before cursor for FIM prompt"
        },
        "zeta.fimSuffixLines": {
          "type": "number",
          "default": 30,
          "description": "Number of context lines after cursor for FIM prompt"
        },
        "zeta.prefetchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Speculatively pre-fetch the next edit prediction after showing one"
        },
        "zeta.maxRelatedFiles": {
          "type": "number",
          "default": 3,
          "description": "Max related files to inject into edit prediction prompt for cross-file context"
        },
        "zeta.maxEditRegions": {
          "type": "number",
          "default": 5,
          "description": "Max edit regions (marker pairs) to parse from a single edit prediction response"
        },
        "zeta.aggressivenessMode": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "conservative", "balanced", "aggressive"],
          "description": "How aggressively to show edit predictions. 'auto' adapts based on accept/reject rate"
        },
        "zeta.aggressivenessThreshold": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Min accept rate (0-1) to keep showing predictions at current level when in 'auto' mode"
        }
      }
    }
  },
  "keybindings": [
    {
      "command": "zeta.acceptAndAdvance",
      "key": "tab",
      "when": "inlineSuggestionVisible && zeta.hasActivePrediction"
    },
    {
      "command": "zeta.jumpToNextEditLocation",
      "key": "alt+down",
      "when": "zeta.hasActivePrediction"
    },
    {
      "command": "zeta.jumpToPrevEditLocation",
      "key": "alt+up",
      "when": "zeta.hasActivePrediction"
    },
    {
      "command": "zeta.dismissPrediction",
      "key": "escape",
      "when": "zeta.hasActivePrediction && !suggestWidgetVisible"
    },
    {
      "command": "zeta.forcePredict",
      "key": "ctrl+enter",
      "when": "editorTextFocus"
    }
  ],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "reload": "npm run build && npx @vscode/vsce package --allow-missing-repository && code --install-extension zeta-vscode-0.1.0.vsix --force"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "esbuild": "^0.25.0"
  }
}
